REDIS_URL=redis://:change-me@127.0.0.1:6379/0
API_HOST=0.0.0.0
API_PORT=8010
SERVICE_STORAGE_DIR=storage
MINERU_COMMAND=mineru
MINERU_DEFAULT_BACKEND=pipeline
MINERU_AUTO_TUNE=true
MINERU_MEMORY_PER_THREAD_MB=1536
CELERY_TASK_DEFAULT_QUEUE=heavy_tasks
CELERY_WORKER_CONCURRENCY=1

